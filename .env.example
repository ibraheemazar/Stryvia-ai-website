# ---------------------------------------------------------------------------
# Stryvia.ai — environment template. Copy to .env.local and fill in.
# Never commit real secrets. The Anthropic key is server-only.
# ---------------------------------------------------------------------------

# The Chat engine (server-side only — never exposed to the client)
ANTHROPIC_API_KEY=
# Model is pinned in code to claude-opus-4-8; override only for testing.
ANTHROPIC_MODEL=claude-opus-4-8

# Supabase — conversations, leads, admin auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is server-only; used by route handlers to write conversations.
SUPABASE_SERVICE_ROLE_KEY=

# Admin access — comma-separated allowlist of emails permitted into /admin
ADMIN_EMAIL_ALLOWLIST=

# Lead notification via Amazon SES. SES_* names are used (not AWS_*) so they
# don't collide with the runtime's reserved AWS_* variables.
LEAD_NOTIFY_TO=
LEAD_NOTIFY_FROM=
SES_REGION=
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=

# Marketing dashboard — optional Slack alerts for automations
SLACK_WEBHOOK_URL=

# Marketing channel connectors (each activates its module when present)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
GA4_PROPERTY_ID=
GA4_CREDENTIALS_JSON=
SEARCH_CONSOLE_SITE=
GOOGLE_SERVICE_ACCOUNT_JSON=
# Performance connectors (Performance tab pulls live data when present)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# Scheduled jobs (Vercel Cron) — set a secret so only Vercel can trigger them
CRON_SECRET=

# PostHog analytics (public — masked session replay configured in code)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Google Analytics 4 (public Measurement ID, G-XXXXXXX). Loaded only after the
# visitor grants analytics consent. Leave blank to disable GA entirely.
# NOTE: if NEXT_PUBLIC_GTM_ID is set, GA4 runs inside GTM instead and this
# direct tag stands down (no double counting) — configure GA4 as a tag in GTM.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager container (public, GTM-XXXXXXX). When set, GTM becomes the
# single container (GA4 + ad pixels live in the GTM UI) with Consent Mode v2.
# Leave blank to keep GA4 firing directly via NEXT_PUBLIC_GA_MEASUREMENT_ID.
NEXT_PUBLIC_GTM_ID=

# Public site URL, used for metadata and hreflang
NEXT_PUBLIC_SITE_URL=https://stryvia.ai

# Data residency — the region actually selected at build time. Drives the
# honest Trust + Privacy copy. e.g. "eu-central-1 (Frankfurt)". If an
# in-Kingdom region is used, set IN_KINGDOM=true.
NEXT_PUBLIC_DATA_REGION=
NEXT_PUBLIC_DATA_IN_KINGDOM=false
