# ---------------------------------------------------------------------------
# admin-core environment template. Copy the bits you need into each site's
# .env.local. The chassis needs the first four blocks; connectors activate as
# you add their keys.
# ---------------------------------------------------------------------------

# Supabase — data + admin auth (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin access — comma-separated allowlist of emails permitted into the panel.
# FAIL-CLOSED: empty allowlist denies everyone.
ADMIN_EMAIL_ALLOWLIST=

# AI copilot + any AI module (server-only)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Connectors (optional; each activates when its keys are present) ---

# Email via Amazon SES (requires the optional @aws-sdk/client-sesv2 package)
SES_REGION=
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
EMAIL_FROM=

# SMS via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# WhatsApp via the Meta Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Slack alerts
SLACK_WEBHOOK_URL=

# GA4 analytics module (optional)
GA4_PROPERTY_ID=
GA4_CREDENTIALS_JSON=
